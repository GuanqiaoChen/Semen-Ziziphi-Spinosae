# Deep-learning runs can be very large. Ignore exploratory runs while allowing
# the preregistered, fully audited run to become a versioned release artifact.
deep_models/outputs/*
!deep_models/outputs/top_journal_preregistered/
!deep_models/outputs/top_journal_preregistered/**

# Preserve the first, numerically identical post-processing pass locally as a
# figure-QA audit snapshot; publish only the corrected canonical figures.
deep_models/outputs/top_journal_preregistered/postprocessing_pre_figure_qa/
deep_models/outputs/top_journal_preregistered/checkpoints_pre_safe_serialization/

